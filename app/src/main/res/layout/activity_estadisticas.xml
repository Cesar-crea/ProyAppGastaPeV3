<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dlMenu"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ffffff"
    tools:context=".EstadisticasActivity">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="#2400A8"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hola, Juan 👋"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen de hoy"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPeriodo"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Spinner
            android:id="@+id/spinnerPeriodo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total gastado"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/cardPeriodo"
        app:layout_constraintStart_toStartOf="@id/cardPeriodo"/>

    <TextView
        android:id="@+id/txtTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S/ 175.40"
        android:textStyle="bold"
        android:textSize="34sp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="@id/txtTitulo"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardGrafico"
        android:layout_width="220dp"
        android:layout_height="220dp"
        app:cardCornerRadius="110dp"
        app:layout_constraintTop_toBottomOf="@id/txtTotal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Gráfico en construccion :D"
            android:textStyle="bold"/>


    </com.google.android.material.card.MaterialCardView>

    <!-- ___________________________________________ -->
    <TextView
        android:id="@+id/txtComida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔵 Comida          45%"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardGrafico"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="40dp"/>

    <TextView
        android:id="@+id/txtTransporte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🟠 Transporte     25%"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtComida"
        app:layout_constraintStart_toStartOf="@id/txtComida"/>

    <TextView
        android:id="@+id/txtServicios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🟢 Servicios      17%"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtTransporte"
        app:layout_constraintStart_toStartOf="@id/txtComida"/>

    <TextView
        android:id="@+id/txtEntretenimiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🟣 Entretenimiento 8%"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtServicios"
        app:layout_constraintStart_toStartOf="@id/txtComida"/>

    <TextView
        android:id="@+id/txtOtros"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚫ Otros           5%"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtEntretenimiento"
        app:layout_constraintStart_toStartOf="@id/txtComida"/>

    <include
        layout="@layout/layout_bottom_menu"
        app:layout_constraintBottom_toBottomOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>